date = ’ü│ %e %B - %A
label = %date%

[module/battery]
type = internal/battery

battery = BAT0
adapter = ADP1

poll-interval = 30

full-at = 99

label-discharging = %percentage%%  ’ēō %time%
label-charging = %percentage%%
label-full = %percentage%%

format-discharging = <ramp-capacity> <label-discharging>
format-full = <ramp-capacity> <label-full>
format-charging = ’ā¦ <label-charging>

ramp-capacity-0 = ’ēä
ramp-capacity-1 = ’ēā
ramp-capacity-2 = ’ēé
ramp-capacity-3 = ’ēü
ramp-capacity-4 = ’ēĆ

[module/pulseaudio]
